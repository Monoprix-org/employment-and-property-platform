const typeLabelMap = {
  rent_out: "For Rent",
  sell_out: "For Sale",
  rent_wanted: "Wanted Rent",
  buy_wanted: "Wanted Buy"
};

const propertyTypeLabelMap = {
  apartment: "Apartment",
  house: "House",
  room: "Room",
  studio: "Studio",
  townhouse: "Townhouse",
  land: "Land",
  commercial: "Commercial",
  other: "Other"
};

function ListingCard({ listing, onView, onSave }) {
  return (
    <div
      style={{
        background: "#fff",
        borderRadius: "18px",
        padding: "18px",
        boxShadow: "0 8px 22px rgba(0,0,0,0.06)",
        border: "1px solid #edf0f6"
      }}
    >
      <div
        style={{
          height: "150px",
          borderRadius: "14px",
          marginBottom: "14px",
          background: "linear-gradient(135deg, #eef1ff 0%, #dfe5ff 100%)",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          color: "#4e54c8",
          fontWeight: "700"
        }}
      >
        {typeLabelMap[listing.listing_type] || "Listing"}
      </div>

      <h3 style={{ marginTop: 0, marginBottom: "10px" }}>{listing.title}</h3>

      <p style={priceStyle}>
        {listing.price ? `$${Number(listing.price).toLocaleString()}` : "Price on request"}
      </p>

      <p style={metaStyle}>
        {[listing.suburb, listing.city, listing.state].filter(Boolean).join(", ") || "Location not provided"}
      </p>

      <p style={metaStyle}>
        {propertyTypeLabelMap[listing.property_type] || "Property"} ·{" "}
        {listing.bedrooms ?? "-"} bed · {listing.bathrooms ?? "-"} bath
      </p>

      <p style={descStyle}>
        {listing.description?.length > 110
          ? `${listing.description.slice(0, 110)}...`
          : listing.description}
      </p>

      <div style={{ display: "flex", gap: "10px", flexWrap: "wrap", marginTop: "14px" }}>
        <button onClick={() => onView(listing.id)} style={mainButtonStyle}>
          View Details
        </button>

        {onSave && (
          <button onClick={() => onSave(listing.id)} style={ghostButtonStyle}>
            Save
          </button>
        )}
      </div>
    </div>
  );
}

const priceStyle = {
  margin: "0 0 8px",
  color: "#4e54c8",
  fontWeight: "700",
  fontSize: "20px"
};

const metaStyle = {
  margin: "0 0 8px",
  color: "#666"
};

const descStyle = {
  color: "#444",
  lineHeight: 1.6,
  minHeight: "50px"
};

const mainButtonStyle = {
  padding: "11px 16px",
  border: "none",
  borderRadius: "12px",
  background: "linear-gradient(135deg, #4e54c8 0%, #8f94fb 100%)",
  color: "#fff",
  cursor: "pointer",
  fontWeight: "700"
};

const ghostButtonStyle = {
  padding: "11px 16px",
  border: "1px solid #d7dce5",
  borderRadius: "12px",
  background: "#fff",
  color: "#333",
  cursor: "pointer",
  fontWeight: "700"
};

export default ListingCard;